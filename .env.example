# LINE Bot 設定 (必填)
LINE_CHANNEL_SECRET=你的_Channel_Secret
LINE_CHANNEL_ACCESS_TOKEN=你的_Channel_Access_Token

# 推播目標 (必填：LINE 使用者 ID 或群組 ID，多個用逗號分隔)
PUSH_TARGETS=U123456789abcdef

# 推播時間 (每週五幾點推播，24小時制，格式 HH:MM)
PUSH_TIME=08:00

# 收集未來幾天的活動 (預設 7 天)
DAYS_AHEAD=7

# Facebook Graph API Token (選填，不填則跳過 Facebook 收集)
# 取得方式：https://developers.facebook.com → 建立 App → Graph API Explorer
FB_ACCESS_TOKEN=

# 伺服器 Port (預設 5000)
PORT=5000
